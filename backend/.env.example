# 默认 SQLite；生产可换为 mysql/postgresql
DATABASE_URL="file:./dev.db"
JWT_SECRET="your-jwt-secret-change-in-production-min-32-chars"
JWT_EXPIRES_IN="2h"
CARD_ENCRYPT_KEY="your-32-char-encryption-key-here!"
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="星云发卡 <noreply@example.com>"
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# 公网根地址（不带尾部 /）
# 支付网关异步通知与同步回跳会拼接到这个地址：
#   ${SITE_URL}/api/payments/notify
#   ${SITE_URL}/api/payments/return
# 本地调试可填 http://localhost:3000（但真实支付需要公网可达地址，可用 ngrok / cloudflared）
SITE_URL="https://yourdomain.com"
